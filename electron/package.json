{
  "name": "pos-system-electron",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist:win": "node build-assets.js && electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.pos.system.desktop",
    "productName": "Vedha Mobile Billing System",
    "icon": "build/icon.png",
    "asarUnpack": [
      "backend/**/*"
    ],
    "files": [
      "main.js",
      "preload.js",
      "frontend-dist/**/*",
      "backend/**/*",
      "package.json",
      "build-assets.js"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
